# ═══ LLM ═══
DEFAULT_LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=your_openai_key

# ═══ Google OAuth2 ═══
GOOGLE_CREDENTIALS_PATH=client_secret_xxx.json
GOOGLE_TOKEN_PATH=token_google.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_TOKEN_EMAIL_PATH=token_google_email.json
GOOGLE_TOKEN_NOTE_PATH=token_google_note.json

# ═══ Providers ═══
CALENDAR_PROVIDER=google
EMAIL_PROVIDER=google
NOTE_PROVIDER=sqlite
MOCK_GRAPH=False

# ═══ JWT ═══
JWT_SECRET_KEY=your_super_secret_jwt_key
JWT_ALGORITHM=HS256

# ═══ Database ═══
DATABASE_URL=sqlite:///./orca.db

# ═══ Microsoft 365 (optional) ═══
# MS_CLIENT_ID=your_client_id
# MS_CLIENT_SECRET=your_client_secret
# MS_TENANT_ID=your_tenant_id
