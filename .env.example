# ── OpenAI ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Microsoft Azure (dùng cho MS Graph Calendar) ───────────────────────
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_TENANT_ID=your-tenant-id

# ID người dùng M365 (UPN hoặc object-id). Để "me" nếu dùng delegated flow.
GRAPH_USER_ID=me

# ── App ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# Đặt True để dùng MockCalendarService (không cần Azure credentials)
MOCK_GRAPH=True
